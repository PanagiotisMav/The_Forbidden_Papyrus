  m_Mesh: {fileID: 10207, guid: 0000000000000000e000000000000000, type: 0}
--- !u!114 &543021164
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 543021159}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b13dd71cce22e31499555bb1b6833f9c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  messages:
  - actorId: 0
    message: 
  - actorId: 0
    message: You are the wizard?
  - actorId: 1
    message: What gave it away? The beard or the cage?
  - actorId: 1
    message: So, that is what brought you here. The Forbidden Papyrus. Every fool
      wants it. Every corpse in this dungeon wanted it too.
  - actorId: 0
    message: I am not like the others.
  - actorId: 1
    message: We will see. The riddle guarding the papyrus is older than this dungeon.
      One mistake, and the guardian wo not wait for a second try.
  - actorId: 0
    message: Do you know the answer?
  - actorId: 1
    message: Yes. I do. But knowledge like that is not given freely.
  - actorId: 0
    message: I just saved your life.
  - actorId: 1
    message: "True. But I value lives less than wisdom. Answer me this: \u201CWhat
      is always running but never moves from its place?\u201D"
  - actorId: 0
    message: ...
  - actorId: 0
    message: ...A clock
  - actorId: 1
    message: ' Maybe you are not like the others after all'
  - actorId: 1
    message: i will give you the answer
  - actorId: 1
    message: "But heed this warning\u2014do not look at the paper when the skeleton
      asks the question"
  - actorId: 1
    message: Because the guardian watches your soul, not your eyes. If it senses
      you are cheating it will strike you down without mercy
  - actorId: 0
    message: 'Do you know how to find the skeleton '
  - actorId: 1
    message: go back to the beginning and follow the Torches
  - actorId: 1
    message: And here take this
  actors:
  - name: Kael
    sprite: {fileID: 21300000, guid: 553556d207fc74b4f85fada0de3521fa, type: 3}
  - name: Wizard
    sprite: {fileID: 21300000, guid: b948c3556a0648c418ae786d4aa691de, type: 3}
  InteractButton: {fileID: 606178382}
  backgroundBox: {fileID: 995158703}
